PREFIX pj: <https://parajudica.org/ns#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# Mark conditions for evaluation from ConditionalImplications with fromAllLabels.
# Mirrors mark/conditional-implication.rq but gates on "all required labels present".

CONSTRUCT {
    ?mark rdf:type pj:ConditionMark ;
          pj:markedCondition ?condition ;
          pj:markedForContainer ?container ;
          pj:markedInScope ?scope ;
          pj:markedFromImplication ?impl .
}
WHERE {
    ?framework pj:declaresImplication ?impl .
    ?impl a pj:ConditionalImplication ;
          pj:fromAllLabels ?fromLabels ;
          pj:toLabel ?toLabel ;
          pj:hasCondition ?condition .

    {
        SELECT ?impl (COUNT(?reqLabel) AS ?reqCount)
        WHERE {
            ?impl pj:fromAllLabels ?fl .
            ?fl rdf:rest*/rdf:first ?reqLabel .
        } GROUP BY ?impl
    }
    {
        SELECT ?impl ?container ?scope (COUNT(DISTINCT ?present) AS ?presentCount)
        WHERE {
            ?impl pj:fromAllLabels ?fl .
            ?fl rdf:rest*/rdf:first ?reqLabel .
            ?container pj:hasLabelInScope ?ls .
            ?ls pj:label ?reqLabel ; pj:scope ?scope .
            BIND(?reqLabel AS ?present)
        } GROUP BY ?impl ?container ?scope
    }
    FILTER(?presentCount >= ?reqCount && ?reqCount > 0)

    FILTER NOT EXISTS {
        ?container pj:hasLabelInScope ?toLs .
        ?toLs pj:label ?toLabel ; pj:scope ?scope .
    }

    BIND(IRI(CONCAT("urn:mark:",
                    MD5(CONCAT(STR(?condition), ":", STR(?container), ":", STR(?scope)))))
         AS ?mark)
    FILTER NOT EXISTS { ?mark rdf:type pj:ConditionMark }
}
